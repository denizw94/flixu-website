---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

// Navigation tabs — Anthropic-style top bar
const tabs = [
  { label: 'Developer Guide', href: '/docs/developer-guide/introduction/' },
  { label: 'API Reference',   href: '/docs/api-reference/overview/' },
  { label: 'Resources',       href: '/docs/resources/overview/' },
  { label: 'Release Notes',   href: '/docs/release-notes/overview/' },
];

// Determine active tab from current URL
const currentPath = Astro.url.pathname;
const activeTab = tabs.find(tab => {
  const section = tab.href.split('/')[2]; // "developer-guide", "api-reference", etc.
  return currentPath.includes(`/${section}/`);
})?.href || tabs[0].href;
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
  </div>
</div>

<!-- Top Navigation Tabs -->
<nav class="top-tabs" aria-label="Documentation sections">
  {tabs.map(tab => (
    <a
      href={tab.href}
      class:list={['top-tab', { active: activeTab === tab.href }]}
    >
      {tab.label}
    </a>
  ))}
</nav>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }
    .social-icons::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        display: grid;
        grid-template-columns:
          minmax(
            calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
            auto
          )
          1fr
          auto;
        align-content: center;
      }
    }
  }

  /* ── Top Navigation Tabs ─────────────────────────────────────── */
  .top-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #e7e5e4;
    background: #FDFCF8;
    padding: 0 var(--sl-nav-pad-x);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .top-tab {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #78716c;
    text-decoration: none;
    padding: 0.625rem 1rem;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .top-tab:hover {
    color: #1c1917;
  }

  .top-tab.active {
    color: #C2410C;
    font-weight: 500;
    border-bottom-color: #C2410C;
  }
</style>
