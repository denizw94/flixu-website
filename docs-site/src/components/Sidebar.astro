---
import type { Props } from '@astrojs/starlight/props';
import DefaultSidebar from '@astrojs/starlight/components/Sidebar.astro';

// We want to filter Astro.props.sidebar to only the group that matches the current path section.
const currentPath = Astro.url.pathname;
// Path looks like /docs/developer-guide/introduction/
// So split('/')[2] will be 'developer-guide'
const section = currentPath.split('/')[2]; 

const sectionToLabelMap: Record<string, string> = {
  'developer-guide': 'Developer Guide',
  'api-reference': 'API Reference',
  'resources': 'Resources',
  'release-notes': 'Release Notes'
};

const expectedLabel = sectionToLabelMap[section || ''];

let sidebarData = Astro.locals.starlightRoute.sidebar || [];

if (expectedLabel && Array.isArray(sidebarData)) {
  // Find the top level group with this label
  const activeGroup = sidebarData.find(item => item.type === 'group' && item.label === expectedLabel);
  
  // If found, overwrite the local route object so the default component picks up the filtered entries!
  if (activeGroup && activeGroup.type === 'group') {
    Astro.locals.starlightRoute.sidebar = activeGroup.entries;
  }
}
---
<DefaultSidebar {...Astro.props} />
