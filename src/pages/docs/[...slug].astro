---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export const prerender = true;
export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map(entry => {
    // entry.slug will be like 'en/developer-guide/introduction'
    // We want the URL to be /docs/developer-guide/introduction
    const slugWithoutLang = entry.slug.replace(/^en\//, '');
    return {
      params: { slug: slugWithoutLang },
      props: { entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'docs'>;
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// Clean slug for the layout to know the active path matching our sidebar config
const activeSlug = entry.slug.replace(/^en\//, '');
---

<DocsLayout 
  title={entry.data.title} 
  description={entry.data.description}
  slug={activeSlug}
  headings={headings}
>
  <Content />
</DocsLayout>
